# Alpaca API Credentials
# 1. Copiá este archivo: cp alpaca.env.example alpaca.env
# 2. Completá tus API keys (paper trading es gratis)
# 3. NUNCA subas alpaca.env a GitHub

ALPACA_API_KEY=PKxxxxxTU_API_KEY_AQUIxxxxx
ALPACA_SECRET_KEY=xxxxxTU_SECRET_KEY_AQUIxxxxx

# Base URLs
ALPACA_PAPER_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
