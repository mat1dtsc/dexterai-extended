# ════════════════════════════════════════════════════════════════════════
# DexterAI Extended — Configuración local
#
# Copia este archivo a .env (o setea como variables de entorno) y
# completa solo los valores que necesites. Todo es opcional excepto si
# quieres activar trading real.
# ════════════════════════════════════════════════════════════════════════

# ─── Anthropic Claude (chat del analista en el panel derecho) ───────────
ANTHROPIC_API_KEY=

# ─── OpenBB (Platform API local en :6900) ────────────────────────────────
# Por default usa solo proveedores gratuitos sin auth (yfinance, SEC, CFTC).
# FRED es gratis pero requiere registro: https://fredaccount.stlouisfed.org/apikey
# Si lo dejas vacío, los endpoints de /economy/* quedan limitados.
FRED_API_KEY=

# ─── Trading: Alpaca (acciones US) ───────────────────────────────────────
# TRADING_MODE controla qué endpoint de Alpaca se usa.
#   disabled  → ninguna orden puede enviarse (modo seguro por default)
#   paper     → usa paper-api.alpaca.markets (cuenta de prueba sin riesgo)
#   live      → usa api.alpaca.markets (dinero real)
TRADING_MODE=disabled
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ─── Trading: Binance (cripto Spot + Futures) ────────────────────────────
# BINANCE_MODE controla a qué endpoint se conecta.
#   disabled  → ninguna orden puede enviarse (default seguro)
#   testnet   → testnet.binance.vision (spot) + testnet.binancefuture.com (futures)
#               Necesitás cuenta separada en https://testnet.binance.vision y
#               https://testnet.binancefuture.com — gratis, USDT virtual
#   live      → api.binance.com + fapi.binance.com (dinero real)
# Para Futures, asegurate de habilitar "Enable Futures Trading" en la API key.
BINANCE_MODE=disabled
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Leverage default cuando abras una posición en Futures (1-125; recomendado 1-5)
BINANCE_DEFAULT_LEVERAGE=5

# ─── Telegram (alertas y señales BUY/SELL al celular) ───────────────────
# 1. Habla con @BotFather en Telegram y crea un bot. Te dará un token.
# 2. Habla con @userinfobot para conocer tu chat_id.
# Sin estos valores, las alertas siguen yendo a la UI pero no al móvil.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Tuning del live stream ─────────────────────────────────────────────
# Intervalo entre ticks del WebSocket (ms). Mínimo efectivo: 3000.
# El sistema autoajusta hacia arriba si la watchlist crece (para respetar
# el rate limit de Yahoo Finance ~10 req/seg).
LIVE_TICK_INTERVAL_MS=5000

# Ventana de dedup de notificaciones (ms). Misma (símbolo, tipo, acción)
# no se reenvía dentro de esta ventana.
NOTIFY_DEDUP_WINDOW_MS=900000

# ─── Debug ──────────────────────────────────────────────────────────────
# MARKETDATA_DEBUG=true   → logs verbose de yahoo-finance2
# OPENBB_DEBUG=true       → logs verbose del cliente OpenBB
